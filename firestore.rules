rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Sementara: siapa aja yang login (akun Google apa aja) boleh nulis.
    // Setelah kamu dapat UID akun Google kamu dari Firebase Console > Authentication > Users,
    // ganti baris "allow write" di tiap collection jadi:
    //   allow write: if request.auth != null && request.auth.uid == "UID_KAMU_DI_SINI";

    match /categories/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /types/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /locations/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /assets/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /counters/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
